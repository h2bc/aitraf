{
  "name": "aitraf-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--gpus=all",
    "--shm-size=2g"
  ],
  "workspaceFolder": "/workspace",
  "mounts": [
    "type=bind,source=${localWorkspaceFolder},target=/workspace",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/ubuntu/.ssh,readonly,type=bind"
  ],
  "postCreateCommand": "uv sync --frozen",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff",
        "openai.chatgpt",
        "tamasfe.even-better-toml",
        "ms-vscode.makefile-tools"
      ]
    }
  },
  "remoteUser": "ubuntu"
}
