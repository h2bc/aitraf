{
  "name": "aitraf-dev",
  "image": "nvcr.io/nvidia/cuda:12.6.0-runtime-ubuntu24.04",
  "runArgs": [
    "--gpus=all",
    "--shm-size=2g"
  ],
  "workspaceFolder": "/workspace",
  "mounts": [
    "type=bind,source=${localWorkspaceFolder},target=/workspace",
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent.sock,type=bind"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent.sock"
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "ubuntu"
    },
    "ghcr.io/devcontainers-extra/features/ffmpeg-apt-get:1": {},
    "ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {},
    "ghcr.io/eitsupi/devcontainer-features/go-task:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff",
        "openai.chatgpt",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "remoteUser": "ubuntu"
}
