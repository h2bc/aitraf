{
  "name": "aitraf-dev",
  "image": "nvcr.io/nvidia/cuda:12.6.0-runtime-ubuntu24.04",
  "runArgs": [
    "--gpus=all",
    "--shm-size=8g"
  ],
  "workspaceFolder": "/workspace",
  "mounts": [
    "type=bind,source=${localWorkspaceFolder},target=/workspace",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerUser": "ubuntu",
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": true,
  "postCreateCommand": "uv sync && uv tool install specify-cli --from git+https://github.com/github/spec-kit.git@v0.10.2",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "ubuntu"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers-extra/features/ffmpeg-apt-get:1": {},
    "ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {},
    "ghcr.io/eitsupi/devcontainer-features/go-task:1": {},
    "ghcr.io/sliekens/devcontainer-features/codex:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff",
        "openai.chatgpt",
        "tamasfe.even-better-toml"
      ]
    }
  }
}
